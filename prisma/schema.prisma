generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String?
  passwordHash   String?
  image          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  runs           Run[]
  coachingSessions CoachingSession[]
  preferences    UserPreferences?
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id                String  @id @default(cuid())
  userId            String  @unique
  preferredCoach    String  @default("motivational")
  distanceUnit      String  @default("km")
  voiceEnabled      Boolean @default(true)
  feedbackFrequency String  @default("medium")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Run {
  id               String           @id @default(cuid())
  userId           String
  status           String           @default("active")
  startedAt        DateTime
  completedAt      DateTime?
  totalDistanceM   Float            @default(0)
  totalDurationS   Int              @default(0)
  avgPaceSPerKm    Float?
  maxPaceSPerKm    Float?
  elevationGainM   Float            @default(0)
  caloriesEst      Float?
  title            String?
  notes            String?
  coachPersonality String?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  points           RunPoint[]
  splits           RunSplit[]
  coachingSession  CoachingSession?

  @@index([userId, startedAt])
}

model RunPoint {
  id                  String   @id @default(cuid())
  runId               String
  timestamp           DateTime
  latitude            Float
  longitude           Float
  altitude            Float?
  accuracy            Float?
  speed               Float?
  heading             Float?
  distanceFromPrevM   Float?
  paceAtPointSPerKm   Float?
  run                 Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, timestamp])
}

model RunSplit {
  id            String @id @default(cuid())
  runId         String
  splitNumber   Int
  distanceM     Float
  durationS     Int
  avgPaceSPerKm Float
  run           Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, splitNumber])
}

model CoachingSession {
  id             String            @id @default(cuid())
  runId          String            @unique
  userId         String
  personality    String
  vapiCallId     String?
  startedAt      DateTime
  endedAt        DateTime?
  run            Run               @relation(fields: [runId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbackEvents CoachingFeedback[]

  @@index([userId, startedAt])
}

model CoachingFeedback {
  id                String          @id @default(cuid())
  coachingSessionId String
  timestamp         DateTime
  triggerType       String
  message           String
  context           String?
  coachingSession   CoachingSession @relation(fields: [coachingSessionId], references: [id], onDelete: Cascade)
}
